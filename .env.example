# Copy these values into your shell environment or deployment platform.
# This project does not load .env files automatically.

SECRET_KEY=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=true

# Required for first-run admin creation in non-dev deployments.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Set true only for local development or trusted intranet webhook targets.
ALLOW_DEFAULT_ADMIN=false
ALLOW_PRIVATE_WEBHOOKS=false

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-a-fernet-key

CHECK_HOUR=8
CHECK_MINUTE=0
TIMEZONE=Asia/Shanghai
